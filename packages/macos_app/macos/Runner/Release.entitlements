<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- No app-sandbox: self-hosted app, never on App Store. Without the sandbox
	     the default Keychain works without keychain-access-groups entitlement,
	     which in turn requires a real Apple Developer team ID / certificate. -->
</dict>
</plist>
