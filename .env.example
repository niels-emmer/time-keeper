# Copy to .env and fill in your values
# .env is gitignored — never commit it

# Shared secret between the frontend nginx and the backend.
# Prevents X-authentik-email header injection on the api.* subdomain by
# ensuring the backend only trusts Authentik identity headers when a matching
# X-Internal-Token header is present (set by frontend nginx, never by NPM).
#
# Generate with:  openssl rand -hex 32
INTERNAL_PROXY_SECRET=replace-with-openssl-rand-hex-32

# No other secrets required. Auth is handled by Authentik + NPM forward auth.
# See docs/integration/auth.md for the Authentik + NPM setup walkthrough.
# See docs/integration/api-subdomain.md for the api.* subdomain setup.
